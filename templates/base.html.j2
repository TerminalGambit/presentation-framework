<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{{ slide_title | default("Slide") }} — {{ meta.title | default("Presentation") }}</title>
  <link rel="stylesheet" href="theme/variables.css"/>
  <link rel="stylesheet" href="theme/base.css"/>
  <link rel="stylesheet" href="theme/components.css"/>
  {% if plugin_css %}
  {% for css_path in plugin_css %}
  <link rel="stylesheet" href="{{ css_path }}"/>
  {% endfor %}
  {% endif %}
  <link href="https://fonts.googleapis.com/css2?family={{ theme.fonts.heading | default('Playfair Display') | replace(' ', '+') }}:wght@400;700&family={{ theme.fonts.subheading | default('Montserrat') | replace(' ', '+') }}:wght@300;400;500;600;700&family={{ theme.fonts.body | default('Lato') | replace(' ', '+') }}:wght@300;400;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
  {% if theme.math %}
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.css" crossorigin="anonymous"/>
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/katex.min.js" crossorigin="anonymous"></script>
  <script defer src="https://cdn.jsdelivr.net/npm/katex@0.16.11/dist/contrib/auto-render.min.js" crossorigin="anonymous"
    onload="renderMathInElement(document.body, {delimiters: [{left: '$$', right: '$$', display: true}, {left: '$', right: '$', display: false}]});"></script>
  <style>
    .katex-display { margin: 0.8em 0; color: var(--pf-contrast-text); }
    .katex { color: var(--pf-contrast-text); }
  </style>
  {% endif %}
  {% if theme.charts %}
  <script src="https://cdn.plot.ly/plotly-2.35.2.min.js" charset="utf-8"></script>
  <script>
  window.__PF_CHART_THEME = {
    accent: '{{ theme.accent | default("#C4A962") }}',
    secondaryAccent: '{{ theme.secondary_accent | default("#5B8FA8") }}',
    fontBody: '{{ theme.fonts.body | default("Lato") }}',
    textColor: getComputedStyle(document.documentElement).getPropertyValue('--pf-contrast-text').trim() || '#ffffff',
    axisColor: getComputedStyle(document.documentElement).getPropertyValue('--pf-text-muted').trim() || '#aaa',
    gridColor: getComputedStyle(document.documentElement).getPropertyValue('--pf-text-faint').trim() || 'rgba(255,255,255,0.1)',
  };
  function _pfBuildTrace(chartType, labels, values, name, color, palette) {
    switch (chartType) {
      case 'line':
        return {type:'scatter',mode:'lines+markers',x:labels,y:values,name:name,line:{color:color,width:3},marker:{color:color,size:8}};
      case 'area':
        return {type:'scatter',mode:'lines',fill:'tozeroy',x:labels,y:values,name:name,line:{color:color},fillcolor:color+'33'};
      case 'scatter':
        return {type:'scatter',mode:'markers',x:labels,y:values,name:name,marker:{color:color,size:10}};
      case 'pie':
        return {type:'pie',labels:labels,values:values,name:name,hole:0,marker:{colors:palette}};
      case 'donut':
        return {type:'pie',labels:labels,values:values,name:name,hole:0.4,marker:{colors:palette}};
      default:
        return {type:'bar',x:labels,y:values,name:name,marker:{color:color}};
    }
  }
  function initChart(el, config, chartType) {
    var t = window.__PF_CHART_THEME;
    var palette = [t.accent, t.secondaryAccent, '#E8D5A3', '#7FC8A8', '#D4A5A5', '#B8A9C9', '#F4978E'];
    var labels = config.labels || config.x || [];
    var values = config.values || config.y || [];
    var series = config.series || [];
    var traces = [];
    if (series.length > 0) {
      for (var i = 0; i < series.length; i++) {
        var s = series[i];
        traces.push(_pfBuildTrace(chartType, labels, s.values || s.y || [], s.name || 'Series '+(i+1), palette[i % palette.length], palette));
      }
    } else {
      traces.push(_pfBuildTrace(chartType, labels, values, '', palette[0], palette));
    }
    var isPie = chartType === 'pie' || chartType === 'donut';
    var layout = {
      paper_bgcolor:'transparent', plot_bgcolor:'transparent',
      font:{family:t.fontBody, color:t.textColor, size:14},
      margin:{l:60,r:30,t:10,b:50},
      showlegend: series.length > 1 || isPie,
      legend:{font:{color:t.textColor}},
    };
    if (!isPie) {
      layout.xaxis = {gridcolor:t.gridColor, zerolinecolor:t.gridColor, tickfont:{color:t.axisColor}};
      layout.yaxis = {gridcolor:t.gridColor, zerolinecolor:t.gridColor, tickfont:{color:t.axisColor}};
    }
    Plotly.newPlot(el, traces, layout, {responsive:true, displayModeBar:false});
  }
  </script>
  {% endif %}
  {% if features.code %}
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/styles/{{ 'github' if is_light else 'github-dark' }}.min.css"/>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/highlight.js/11.11.1/highlight.min.js"></script>
  <script>document.addEventListener('DOMContentLoaded', () => hljs.highlightAll());</script>
  {% endif %}
  {% if features.mermaid %}
  <script src="https://cdnjs.cloudflare.com/ajax/libs/mermaid/11.12.0/mermaid.min.js"></script>
  <script>
    mermaid.initialize({ startOnLoad: false, theme: '{{ "default" if is_light else "dark" }}' });
    document.addEventListener('DOMContentLoaded', async () => {
      await mermaid.run({ querySelector: '.mermaid' });
      document.body.setAttribute('data-pf-ready', '1');
    });
  </script>
  {% endif %}
  {% if features.map %}
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css"/>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
  {% endif %}
  {% block head_extra %}{% endblock %}
</head>
<body>
  <div class="slide-container{% block container_class %}{% endblock %}" data-density="{{ density | default('normal') }}" role="region" aria-label="{{ slide_title | default('Slide') }}" tabindex="0" style="{% if density == 'high' %}--pf-body-size: 12px; --pf-card-pad: 14px; --pf-header-size: 36px; --pf-gap: 18px;{% else %}--pf-body-size: 14px; --pf-card-pad: 20px; --pf-header-size: 42px; --pf-gap: 25px;{% endif %}{% if slide.style %} {{ slide.style }}{% endif %}">
    <div class="bg-pattern"></div>
    {% block decorations %}{% endblock %}
    {% block content %}{% endblock %}
    <div class="page-number">{{ page_number | default("") }}</div>
    {% if slide.notes %}
    <aside class="notes">{{ slide.notes }}</aside>
    {% endif %}
  </div>
  <button class="pf-hc-toggle" aria-label="Toggle high-contrast mode" title="Toggle high-contrast mode (H)">
    <i class="fa-solid fa-circle-half-stroke"></i>
  </button>
  <style>
  .pf-hc-toggle {
    position: fixed;
    bottom: 10px;
    right: 10px;
    z-index: 9999;
    background: rgba(128, 128, 128, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50%;
    width: 32px;
    height: 32px;
    cursor: pointer;
    color: inherit;
    font-size: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.4;
    transition: opacity 0.2s;
  }
  .pf-hc-toggle:hover { opacity: 1; }
  </style>
  <script>
  (function() {
    var container = document.querySelector('.slide-container');
    var btn = document.querySelector('.pf-hc-toggle');
    function toggleHC() {
      if (container) container.classList.toggle('pf-high-contrast');
    }
    if (btn) btn.addEventListener('click', toggleHC);
    document.addEventListener('keydown', function(e) {
      if (e.key === 'h' || e.key === 'H') {
        // Don't trigger if user is typing in an input/textarea
        if (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA') return;
        toggleHC();
      }
    });
  })();
  </script>
  <script>
  {% if not features.mermaid %}
  document.addEventListener('DOMContentLoaded', () => {
    {% if features.map %}
    if (!document.body.hasAttribute('data-pf-ready')) {
      setTimeout(() => document.body.setAttribute('data-pf-ready', '1'), 100);
    }
    {% else %}
    document.body.setAttribute('data-pf-ready', '1');
    {% endif %}
  });
  {% endif %}
  </script>
</body>
</html>
