<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>{{ slide_title | default("Slide") }} — {{ meta.title | default("Presentation") }}</title>
  <link rel="stylesheet" href="theme/variables.css"/>
  <link rel="stylesheet" href="theme/base.css"/>
  <link rel="stylesheet" href="theme/components.css"/>
  <link href="https://fonts.googleapis.com/css2?family={{ theme.fonts.heading | default('Playfair Display') | replace(' ', '+') }}:wght@400;700&family={{ theme.fonts.subheading | default('Montserrat') | replace(' ', '+') }}:wght@300;400;500;600;700&family={{ theme.fonts.body | default('Lato') | replace(' ', '+') }}:wght@300;400;700&family=IBM+Plex+Mono:wght@400;500;600&display=swap" rel="stylesheet"/>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"/>
  {% block head_extra %}{% endblock %}
</head>
<body>
  <div class="slide-container{% block container_class %}{% endblock %}" data-density="{{ density | default('normal') }}" style="{% if density == 'high' %}--pf-body-size: 12px; --pf-card-pad: 14px; --pf-header-size: 36px; --pf-gap: 18px;{% else %}--pf-body-size: 14px; --pf-card-pad: 20px; --pf-header-size: 42px; --pf-gap: 25px;{% endif %}">
    <div class="bg-pattern"></div>
    {% block decorations %}{% endblock %}
    {% block content %}{% endblock %}
    <div class="page-number">{{ page_number | default("") }}</div>
    {% if slide.notes %}
    <aside class="notes">{{ slide.notes }}</aside>
    {% endif %}
  </div>
</body>
</html>
